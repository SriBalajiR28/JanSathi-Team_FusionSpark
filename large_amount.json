    {
      "parameters": {
        "jsCode": "const loanAmountFromForm = $(\"Code in JavaScript1\").all()[0]?.json?.Loanamount;\nconst userName = $(\"Code in JavaScript1\").all()[0]?.json?.Name;\nconst allMatchCred = $(\"Code in JavaScript\").all()[0]?.json?.ALL_MATCH_CRED || [];\n\nconst schemesText = allMatchCred.map(scheme => \n  `- ${scheme[\"Schema _Name\"]}: Loan Amount ${scheme[\" Loan_Amount\"]} INR, Interest Rate ${scheme[\" Interest_Rate\"]}%, EMI ${scheme[\" EMI\"]} INR`\n).join(\"\\n\");\n\nreturn [{ json: { loanAmountRequested: loanAmountFromForm, userName: userName, schemesText: schemesText, schemes: allMatchCred } }];"
      },
