      "parameters": {
        "jsCode": "const allSchemes = $input.all().map((item) => item.json);\nconst creditScores = $(\"Get row(s) in sheet\")\n  .all()\n  .map((item) => item.json);\n\nconst matchedCreditScores = allSchemes.filter((scheme) => {\n  const matchedCredit = creditScores.find(\n    (credit) => credit[\"Credit Score\"] >= scheme.Min_Credit_Score,\n  );\n  return matchedCredit !== undefined;\n});\n\nreturn { ALL_MATCH_CRED: matchedCreditScores };\n"
      },
